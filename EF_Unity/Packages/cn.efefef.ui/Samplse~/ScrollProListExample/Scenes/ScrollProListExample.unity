  IptRemoveIndex: {fileID: 1977009887}
  IptScrollToIndex: {fileID: 198164689}
  IptScrollToIndexAnimated: {fileID: 1916133822}
  SampleTexts:
  - "\u77ED\u6587\u672C"
  - "\u8FD9\u662F\u4E00\u6BB5\u4E2D\u7B49\u957F\u5EA6\u7684\u6587\u672C\uFF0C\u7528\u6765\u6A21\u62DF\u804A\u5929\u6D88\u606F\u7684\u4E0D\u540C\u9AD8\u5EA6\u3002"
  - "\u8FD9\u6BB5\u6587\u672C\u6BD4\u8F83\u957F\u3002\u5F53 VerticalLayoutGroup \u548C
    ContentSizeFitter \u534F\u540C\u5DE5\u4F5C\u65F6\uFF0Citem \u7684\u5B9E\u9645\u9AD8\u5EA6\u7531\u5B50\u7269\u4F53\u7684\u7D2F\u52A0\u9AD8\u5EA6\u51B3\u5B9A\u3002\u5F00\u542F
    Auto Rebuild Layout \u540E\uFF0C\u7EC4\u4EF6\u4F1A\u5728 OnUpdateItem \u586B\u5145\u5B8C\u5185\u5BB9\u540E\u81EA\u52A8\u8C03\u7528
    ForceRebuildLayoutImmediate \u5E76\u6D4B\u91CF\u771F\u5B9E\u9AD8\u5EA6\uFF0C\u7136\u540E\u4FEE\u6B63\u540E\u7EED\u6240\u6709
    item \u7684\u7D2F\u79EF\u4F4D\u7F6E\u3002"
  - "\u8D85\u77ED"
  - "\u53C8\u662F\u4E00\u6BB5\u4E2D\u7B49\u957F\u5EA6\u7684\u6587\u672C\uFF0C\u7528\u6765\u6F14\u793A\u81EA\u9002\u5E94\u5E03\u5C40\u3002"
  ExpandText: "\" [ \u5C55\u5F00\u6F14\u793A\u6570\u636E ] \u8FD9\u4E9B\u5185\u5BB9\u4F1A\u6491\u5F00\u9AD8\u5EA6\uFF0C\u89E6\u53D1\u5E03\u5C40\u52A8\u753B\u3002\""
